# ============================================================
# AI 换发型 / 换发色 智能镜系统 — 环境变量配置
# ============================================================
# 使用方法: cp .env.example .env 并按需修改
# 启动: ./start.sh
# ============================================================

# ── 服务端配置 ──

# 管理后台 API Key (默认: hair-admin-dev-2026)
# 生产环境请务必修改！
ADMIN_API_KEY=hair-admin-dev-2026


# ── RunningHub API (必填) ──
# 核心 AI 处理服务: 换发型 / 换发色 / 3D 视频

RUNNINGHUB_API_KEY=your_runninghub_api_key
RUNNINGHUB_WEBAPP_ID=your_hairstyle_webapp_id     # 换发型 Webapp ID
RUNNINGHUB_COLOR_WEBAPP_ID=your_color_webapp_id    # 换发色 Webapp ID
RUNNINGHUB_COLOR_PRE_WEBAPP_ID=                    # 发色预处理 Webapp ID (可选)
RUNNINGHUB_3D_WEBAPP_ID=                           # 3D 视频 Webapp ID (可选)

# 节点 ID (一般不需要修改)
# RUNNINGHUB_HAIRSTYLE_USER_NODE_ID=77
# RUNNINGHUB_HAIRSTYLE_HAIR_NODE_ID=24
# RUNNINGHUB_COLOR_USER_NODE_ID=76
# RUNNINGHUB_COLOR_HAIR_NODE_ID=81


# ── 火山引擎 / 豆包 (3D 视频, 可选) ──
# 用于 360° 发型展示视频生成

# ARK_API_KEY=your_volcengine_ark_key
# VOLCENGINE_3D_MODEL=doubao-seedance-1-5-pro-251215
# VOLCENGINE_3D_BASE_URL=https://ark.cn-beijing.volces.com/api/v3/contents/generations/tasks
# VOLCENGINE_3D_PROMPT=人物优雅地360度转身，以展示其发型。 --duration 6 --camerafixed false --watermark true
# VOLCENGINE_3D_RATIO=9:16
# VOLCENGINE_3D_DURATION=6
# VOLCENGINE_3D_RESOLUTION=1080p


# ── PixVerse / 拍我 AI (3D 视频, 可选) ──
# 替代火山引擎的 3D 视频生成方案

# PAI_VIDEO_API_KEY=your_pai_api_key
# PAI_VIDEO_BASE_URL=https://app-api.pixverseai.cn
# PAI_VIDEO_MODEL=v6
# PAI_VIDEO_PROMPT=单镜头无剪切，人物站在*纯白*的背景下，360度转身，以展示其发型。
# PAI_VIDEO_DURATION=6
# PAI_VIDEO_QUALITY=1080p


# ── Gemini 图像预处理 (可选) ──
# 通过 OpenRouter 调用 Gemini 对输入图像进行预处理

# OPENROUTER_API_KEY=your_openrouter_key


# ── 3D 提供商选择 ──
# auto       = 自动选择 (优先 Pai → Volcengine → RunningHub)
# pai        = 强制使用 PixVerse
# volcengine = 强制使用火山引擎
# runninghub = 强制使用 RunningHub
# VIDEO_3D_PROVIDER=auto


# ── Railway 配置 ──
# RAILWAY_VOLUME_MOUNT_PATH=/data
