<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/medium_grey">

    <!-- 顶部栏 -->
    <TextView
        android:id="@+id/tvDone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        android:text="完成"
        android:textColor="@color/white"
        android:textSize="18sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- 右上角选中图标 -->
    <ImageView
        android:id="@+id/ivCheckMark"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:layout_marginTop="12dp"
        android:layout_marginEnd="16dp"
        android:src="@drawable/ic_check"
        android:background="@drawable/rounded_circle_icon"
        android:padding="6dp"
        android:tint="@color/white"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- 左侧 Guideline - 给按钮留出空间 -->
    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guidelineLeft"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_begin="48dp" />

    <!-- 右侧 Guideline - 给按钮留出空间 -->
    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guidelineRight"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_end="48dp" />

    <!-- 左切换按钮 - 在 guideline 左侧 -->
    <ImageView
        android:id="@+id/btnPrevious"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_marginEnd="8dp"
        android:src="@drawable/ic_prev"
        android:scaleType="fitCenter"
        android:clickable="true"
        android:focusable="true"
        app:layout_constraintBottom_toBottomOf="@+id/cardPreview"
        app:layout_constraintEnd_toStartOf="@+id/guidelineLeft"
        app:layout_constraintTop_toTopOf="@+id/cardPreview" />

    <!-- 图片预览区域 - 在两个 guideline 之间 -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardPreview"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="24dp"
        android:layout_marginBottom="8dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="8dp"
        app:layout_constraintBottom_toTopOf="@+id/tvHint"
        app:layout_constraintEnd_toStartOf="@+id/guidelineRight"
        app:layout_constraintStart_toEndOf="@+id/guidelineLeft"
        app:layout_constraintTop_toBottomOf="@+id/tvDone"
        app:layout_constraintDimensionRatio="3:4">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <com.hairstyle.generator.ui.widget.ImageComparerView
                android:id="@+id/imageComparer"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />

            <!-- 建议烫染标签 -->
            <TextView
                android:id="@+id/tvSuggestion"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom|end"
                android:layout_margin="12dp"
                android:background="@drawable/result_label_bg"
                android:paddingHorizontal="8dp"
                android:paddingVertical="4dp"
                android:text="建议烫染"
                android:textColor="@color/medium_grey"
                android:textSize="12sp" />
        </FrameLayout>
    </androidx.cardview.widget.CardView>

    <!-- 右切换按钮 - 在 guideline 右侧 -->
    <ImageView
        android:id="@+id/btnNext"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_marginStart="8dp"
        android:src="@drawable/ic_next"
        android:scaleType="fitCenter"
        android:clickable="true"
        android:focusable="true"
        app:layout_constraintBottom_toBottomOf="@+id/cardPreview"
        app:layout_constraintStart_toEndOf="@+id/guidelineRight"
        app:layout_constraintTop_toTopOf="@+id/cardPreview" />

    <!-- 提示文字 -->
    <TextView
        android:id="@+id/tvHint"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="12dp"
        android:gravity="center"
        android:text="该效果需要调整头发塑形状态及色彩饱和度，请与发型师沟通确认。"
        android:textColor="@color/white"
        android:textSize="12sp"
        app:layout_constraintBottom_toTopOf="@+id/bottomButtonsLayout"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/cardPreview" />

    <!-- 底部按钮区域 -->
    <LinearLayout
        android:id="@+id/bottomButtonsLayout"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="24dp"
        android:gravity="center"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <Button
            android:id="@+id/btnRegisterSave"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:paddingVertical="12dp"
            android:text="注册并保存"
            android:textSize="13sp"
            style="@style/PrimaryButton" />

        <Button
            android:id="@+id/btnChangeColor"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginHorizontal="4dp"
            android:paddingVertical="12dp"
            android:text="换发色"
            android:textSize="13sp"
            style="@style/SecondaryButton" />

        <Button
            android:id="@+id/btn3DView"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:paddingVertical="12dp"
            android:text="3d展示"
            android:textSize="13sp"
            style="@style/SecondaryButton" />
    </LinearLayout>

    <!-- 底部缩略图预览 -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvThumbnails"
        android:layout_width="0dp"
        android:layout_height="80dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="8dp"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@+id/bottomButtonsLayout"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
